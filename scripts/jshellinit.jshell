ArtificialGamePosition newTree(long seed) {
    System.out.println("seed = "+seed);
    return new ArtificialGamePosition(true, seed, 5, 100, 5, 1.1, 0.25);
}
ArtificialGamePosition newTree() {
    return newTree(new Random().nextLong());
}
VariantAGP newAGP(long seed) {
	System.out.println("seed = "+seed);
	return new VariantAGP(true, seed, 5, Generator.Width.FIXED, 100, Generator.MINRANGE(2, Generator.MAXDEPTH(2_000, Generator.DEFAULT(5))), 1.1, 0.25);
}
VariantAGP newAGP() {
