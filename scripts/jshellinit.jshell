}

void measure(Supplier<SearchResult<?,?>> search, boolean printTree) {
    Instant A = Instant.now();
    var res = search.get();
    Instant B = Instant.now();
    System.out.println("Time spent (ms): "+Duration.between(A,B).toNanos()/1_000_000.);
    System.out.println(res.describe());
	if (printTree) System.out.println(res.root().printTree(1));
}
void measure(Supplier<SearchResult<?,?>> search) {
	measure(search, false);
}
void measure(int repetitions, Supplier<SearchResult<?,?>> search, Runnable computationPrep) {
	long[] times = new long[repetitions];
	long[] expands = new long[repetitions];
	long[] evals = new long[repetitions];
	long[] nodes = new long[repetitions];
	boolean[] solved = new boolean[repetitions];
	int num_solved = 0;
	
	for (int i=0; i < repetitions; i++) {
		computationPrep.run();
		// System.out.format("starting repetition %d out of %d\n",i+1,repetitions);
		Instant A = Instant.now();
		var res = search.get();
		Instant B = Instant.now();
		// System.out.println("  done.");
		System.out.print(".");
		if (i == repetitions - 1)
			System.out.println();
		times[i] = Duration.between(A,B).toNanos();
		var M = res.mainMetrics();
		expands[i] = M.expansions();
		evals[i] = M.evaluations();
		nodes[i] = M.maxObservedNodes();
		solved[i] = res.complete();
		if (solved[i]) num_solved++;
	}
	double mean_time, mean_expands, mean_evals, mean_nodes;
	mean_time = mean_expands = mean_evals = mean_nodes = 0.;
	for (int i=0; i < repetitions; i++) {
		if (num_solved > 0 && solved[i]) {
			mean_time    += (double) (times[i] / 1_000_000.) / num_solved;
			mean_expands += (double) expands[i] / num_solved;
			mean_evals   += (double) evals[i] / num_solved;
			mean_nodes   += (double) nodes[i] / num_solved;
		} else if (num_solved == 0) {
			mean_time    += (double) (times[i] / 1_000_000.) / repetitions;
			mean_expands += (double) expands[i] / repetitions;
			mean_evals   += (double) evals[i] / repetitions;
			mean_nodes   += (double) nodes[i] / repetitions;
		}
	}
	System.out.format("Solved %d out of %d repetitions\n",num_solved,repetitions);
	System.out.format("Average time spent (ms): %.1f\n",mean_time);
	System.out.format("Average num expansions : %.0f\n",mean_expands);
	System.out.format("Average num evaluations: %.0f\n",mean_evals);
	System.out.format("Average maximum nodes  : %.0f\n",mean_nodes);
}
void measure(int repetitions, Supplier<SearchResult<?,?>> search) {
	measure(repetitions, search, () -> {});
}

BstarBasic bstar(StrategyFunction sf) { return new BstarBasic(sf); }
BstarBasic bstar() { return bstar(StrategyFunction.ALTERNATE()); }

