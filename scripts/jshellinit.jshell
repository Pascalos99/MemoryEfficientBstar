<P extends IGamePosition<P>> void testTree(P tree) {
    measure(() -> bstar().search(tree, Duration.ofSeconds(3)));
}

void dumpTable(Table miniT) {
    int num_empty = 0;
    int num_total = 1 << miniT.keySize();
    StringBuilder large = new StringBuilder();
    StringBuilder small = new StringBuilder();
    for (int i=0; i < num_total; i++) {
      if (miniT.hasEntry(i)) {
        String str = String.format("%3d: (% 3.0f,% 3.0f)\n",i,miniT.lower(i),miniT.upper(i));
        small.append(str);
        large.append(str);
      } else {
        String str = String.format("%3d: empty\n", i);
        large.append(str);
        num_empty++;
      }
    } double frac = (double) num_empty / num_total;
    if (frac > 0.4)
        System.out.println(small.toString());
    else
        System.out.println(large.toString());
    System.out.format(Locale.CANADA, "in total %d out of %d entries are filled (%4.2f%%)\n",num_total-num_empty,num_total,100*(1.-frac));
}
void measureTable(Table TT) {
	int num_filled = 0;
    int num_total = 1 << TT.keySize();
    for (int i=0; i < num_total; i++)
      if (TT.hasEntry(i)) num_filled++;
    System.out.format(Locale.CANADA, "in total %d out of %d entries are filled (%4.2f%%)\n",num_filled,num_total,100*((double)num_filled/num_total));
}

Supplier<ArtificialGamePosition> newTree(long difficulty, int reps, Duration time_limit) {
    Random r = new Random();
    int width = 2;
    int num_alts = 2;
    double growth = 1.;
    double force_chance = 0.;
    long expansions = 0l;
    int solved = reps;
    int step = 0;
    while (expansions < difficulty*reps && solved > 0) {
	if (step > 0) {
	    int choice = r.nextInt((force_chance < 1)? 4 : 3);
	    if (choice == 0) { width++; System.out.format("increased width (%d)\n", width); }
	    if (choice == 1) { num_alts++; System.out.format("increased num-alts (%d)\n", num_alts); }
	    if (choice == 2) { growth *= 1.1; System.out.format(Locale.CANADA, "increased growth (%.2f)\n", growth); }
	    if (choice == 3) { force_chance += 0.1; System.out.format(Locale.CANADA, "increased force chance (%.1f)\n", force_chance); }
	}
	expansions = 0l;
	solved = 0;
	for (int iter=0; iter < reps; iter++) {
	    var tree = new ArtificialGamePosition(true,r.nextLong(), width, 100, num_alts, growth, force_chance);
	    var res = bstar().search(tree,time_limit);
	    solved += res.complete() ? 1 : 0;
	    expansions += res.mainMetrics().expansions();
		System.out.print(".");
	} System.out.println();
	System.out.format(Locale.CANADA, "got %.2f%% of the # expansions goal (%d solved)\n",100. * (double)expansions / (difficulty * reps), solved);
	step++;
    }
    final int _width = width, _num_alts = num_alts;
    final double _growth = growth, _force_chance = force_chance;
    return () -> new ArtificialGamePosition(true, r.nextLong(), _width, 100, _num_alts, _growth, _force_chance);
}

ArtificialGamePosition findCase(Supplier<ArtificialGamePosition> getter, Function<ArtificialGamePosition, Long> metricA, Function<ArtificialGamePosition, Long> metricB, int reps, Duration time_limit) {
	// find a tree where metricB < metricA for every rep
	Instant start = Instant.now();
	findtree: while (Duration.between(start, Instant.now()).compareTo(time_limit) < 0) {
		ArtificialGamePosition tree = getter.get();
		success: {
			for (int i=0; i < reps; i++)
				if (metricA.apply(tree) <= metricB.apply(tree)) break success;
			return tree;
		}
	}
	return null;
}

Function<ArtificialGamePosition,Long> searchMetric(Function<ArtificialGamePosition, SearchResult<?,?>> search, long diff) {
	return p -> {
		var res = search.apply(p);
		if (res.complete()) return res.mainMetrics().expansions() + diff;
		return Long.MAX_VALUE;
	};
}
Function<ArtificialGamePosition,Long> searchMetric(Function<ArtificialGamePosition, SearchResult<?,?>> search, double factor) {
	return p -> {
		var res = search.apply(p);
		if (res.complete()) return Math.round(res.mainMetrics().expansions() * factor);
		return Long.MAX_VALUE;
	};
}
Function<ArtificialGamePosition,Long> searchMetric(Function<ArtificialGamePosition, SearchResult<?,?>> search) {
	return searchMetric(search, 0l);
}